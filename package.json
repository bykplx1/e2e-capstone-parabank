{
  "name": "e2e-capstone-parabank",
  "version": "0.1.0",
  "private": true,
  "description": "Resilient cross-browser E2E Playwright/TypeScript suite for ParaBank (QA capstone).",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "playwright test",
    "test:unit": "playwright test tests/unit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "axe-core": "^4.12.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
