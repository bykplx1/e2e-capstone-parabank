# Base URL for the ParaBank application under test.
# Defaults to the local Docker `parasoft/parabank` instance when unset.
# The app is served under the `/parabank` context path, so test routes
# include it, e.g. page.goto('/parabank/index.htm').
#
# Local Docker (default):   http://localhost:8080
# Public demo instance:     https://parabank.parasoft.com
PARABANK_URL=http://localhost:8080
